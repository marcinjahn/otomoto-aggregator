# URL of the deployed Cloudflare Worker CORS proxy.
# For local dev, run the worker with `pnpm dev` in ../worker and use e.g. http://127.0.0.1:8787
VITE_PROXY_URL=http://127.0.0.1:8787

# Base path for GitHub Pages project site, e.g. "/otomoto-aggregator".
# Leave empty when running locally or deploying to a root domain.
BASE_PATH=
